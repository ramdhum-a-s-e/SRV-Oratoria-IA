# ── Entorno local (PC con GPU NVIDIA + CUDA Toolkit) ─────────────────────────
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=int8
WHISPER_MODEL_LIVE=medium
WHISPER_MODEL_FINAL=medium

# ── Entorno producción (Oracle Cloud ARM — sin GPU) ───────────────────────────
# WHISPER_DEVICE=cpu
# WHISPER_COMPUTE_TYPE=int8
# WHISPER_MODEL_LIVE=small
# WHISPER_MODEL_FINAL=medium

# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://usuario:password@localhost:5432/srv_db

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_una_clave_secreta_larga_y_aleatoria
JWT_EXPIRE_MINUTES=1440
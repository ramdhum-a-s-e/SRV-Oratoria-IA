# ──────────────────────────────────────────────────────────────────────────────
# SRV-Oratoria-IA — Variables de entorno
# Copia este archivo como .env y completa los valores reales
# NUNCA subas el archivo .env a GitHub
# ──────────────────────────────────────────────────────────────────────────────

# ── Base de datos ─────────────────────────────────────────────────────────────
# Desarrollo local (SQLite — sin configuración):
DATABASE_URL=sqlite:///./srv_dev.db

# Producción (Supabase — PENDIENTE: completar cuando tengas la URL):
# Ve a: Supabase → Settings → Database → Connection string → URI
# Usa el "Session pooler" en puerto 6543 (compatible con SQLAlchemy sin pgbouncer)
# DATABASE_URL=postgresql://postgres.XXXXXXXXXXXX:tupassword@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── Autenticación JWT ─────────────────────────────────────────────────────────
# Genera un secret seguro con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRET_SEGURO_DE_64_CARACTERES
JWT_EXPIRE_MINUTES=1440

# ── Whisper (Railway — CPU, sin GPU) ─────────────────────────────────────────
# "small"  → ~500 MB RAM, suficiente para Railway Starter (512 MB)
# "medium" → ~1.5 GB RAM, requiere plan con más memoria
# IMPORTANTE: build.sh descarga el modelo de WHISPER_MODEL_FINAL en build time.
# Si cambias este valor, el build debe correr de nuevo para re-descargar.
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_MODEL_LIVE=small
WHISPER_MODEL_FINAL=medium

# ── CORS — URL del frontend en Vercel ────────────────────────────────────────
# Reemplaza con tu URL real de Vercel una vez que hagas el primer deploy.
# Ejemplo: ALLOWED_ORIGIN=https://srv-oratoria-ia.vercel.app
# PENDIENTE: definir cuando esté disponible la URL de Vercel
ALLOWED_ORIGIN=PENDIENTE_URL_VERCEL